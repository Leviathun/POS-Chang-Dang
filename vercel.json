{
  "version": 2,
  "outputDirectory": "dist",
  "regions": ["hnd1"],
  "rewrites": [
    {
      "source": "/api/line/webhook",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/$1"
    }
  ]
}
