{
  "name": "pos-chang-dang",
  "version": "1.0.0",
  "description": "ระบบ POS ร้านไก่ทอดช้างแดง — Point of Sale for Chang Dang Fried Chicken",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "backend": "nodemon server.js",
