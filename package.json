{
  "name": "pos-chang-dang",
  "version": "1.0.0",
  "description": "ระบบ POS ร้านไก่ทอดช้างแดง — Point of Sale for Chang Dang Fried Chicken",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "node backend/server.js",
    "backend": "nodemon backend/server.js",
    "frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build --workspace=frontend"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "fried-chicken",
    "thai"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^10.0.0",
    "nodemon": "^3.1.9"
  }
}
