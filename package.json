    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "promptpay-qr": "^0.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "nodemon": "^3.1.9"
  }
}
